# Streamlit Cloud secrets — copy these into the dashboard:
#   App settings → Secrets → paste this content (replace placeholder values)
#
# Locally, prefer .env (we use python-dotenv); secrets.toml is for cloud.

# Storage backend selector
STORAGE_BACKEND = "r2"

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT          = "https://616dd6c83d008710f8c2eba3455e5fc2.r2.cloudflarestorage.com"
R2_BUCKET            = "wushu"
R2_ACCESS_KEY_ID     = "REPLACE_WITH_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY = "REPLACE_WITH_R2_SECRET_ACCESS_KEY"
R2_URL_TTL           = "3600"

# Supabase (Transaction Pooler URL — port 6543)
SUPABASE_DB_URL = "postgresql://postgres.hlrldzryifasvbrwzuhb:REPLACE_WITH_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres"

# Anthropic (for translation feature)
ANTHROPIC_API_KEY = "REPLACE_WITH_ANTHROPIC_KEY"

# Misc
WUSHU_DEFAULT_LANG = "ko"
